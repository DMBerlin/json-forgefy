{
  "name": "json-forgefy-playground",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive playground for testing json-forgefy",
  "scripts": {
    "install:latest": "pnpm add json-forgefy@latest",
    "build": "node src/scripts/build-browser.js",
    "serve": "npx http-server -p 8000 -o",
    "dev": "pnpm run build && pnpm run serve"
  },
  "dependencies": {
    "json-forgefy": "latest"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
